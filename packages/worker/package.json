{
  "name": "all-things-ai-worker",
  "version": "0.12.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "sync:openrouter:remote": "node ./scripts/sync-openrouter-remote.mjs",
    "db:migrate": "wrangler d1 execute all-things-ai-db --local --file=src/db/schema.sql",
    "db:seed": "wrangler d1 execute all-things-ai-db --local --file=src/db/seed.sql",
    "db:migrate:remote": "wrangler d1 execute all-things-ai-db --remote --file=src/db/schema.sql",
    "db:seed:remote": "wrangler d1 execute all-things-ai-db --remote --file=src/db/seed.sql"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "fast-xml-parser": "^5.0.0",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
